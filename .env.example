# AccessGate Environment Variables Configuration

# Server Config
PORT=5000
NODE_ENV=development

# Database Config
MONGO_URI=mongodb://mongo:27017/accessgate
# For local dev without docker:
# MONGO_URI=mongodb://localhost:27017/accessgate

# JWT Configuration
JWT_ACCESS_SECRET=super_secret_access_key_change_me_in_production
JWT_REFRESH_SECRET=super_secret_refresh_key_change_me_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Config
CLIENT_URL=http://localhost:5173
